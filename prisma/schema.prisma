generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  email       String   @unique
  password    String
  permissions String[]
  role        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
